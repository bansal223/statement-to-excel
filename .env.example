# Copy to .env and fill in OPENAI_API_KEY. .env is git-ignored.
# Keep values UNQUOTED (works with pydantic-settings and `docker --env-file`).
OPENAI_API_TYPE=openai
OPENAI_API_BASE_ENDPOINT=https://truefoundry.innovaccer.com/api/llm/api/inference/openai/
OPENAI_API_VERSION=2025-08-01
OPENAI_API_KEY=
OPENAI_USE_GATEWAY=True
OPENAI_CHAT_MODEL=openai/gpt-5.1
OPENAI_EMBEDDINGS_MODEL=openai/text-embedding-3-small

STATEMENT_DATE_FMT=%d/%m/%y
